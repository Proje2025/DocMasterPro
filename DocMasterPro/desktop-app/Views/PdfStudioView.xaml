<UserControl x:Class="DocConverter.Views.PdfStudioView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>

    <Style x:Key="StudioButton" TargetType="Button">
      <Setter Property="Padding" Value="12,7"/>
      <Setter Property="Margin" Value="3"/>
      <Setter Property="MinWidth" Value="82"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="#D7DEE8"/>
      <Setter Property="Background" Value="#FFFFFF"/>
      <Setter Property="Foreground" Value="#172033"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#EEF4FF"/>
                <Setter Property="BorderBrush" Value="#9DBCF7"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="PrimaryStudioButton" BasedOn="{StaticResource StudioButton}" TargetType="Button">
      <Setter Property="Background" Value="#2563EB"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="BorderBrush" Value="#2563EB"/>
    </Style>

  </UserControl.Resources>

  <Grid Background="#F3F6FA"
        AllowDrop="True"
        DragEnter="PdfStudio_DragEnter"
        DragOver="PdfStudio_DragOver"
        Drop="PdfStudio_Drop">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#DFE5EE" BorderThickness="0,0,0,1" Padding="14,10">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Orientation="Horizontal">
          <Button Content="PDF Aç" Style="{StaticResource PrimaryStudioButton}" Command="{Binding OpenPdfCommand}"/>
          <Button Content="Kaydet" Style="{StaticResource StudioButton}" Command="{Binding SaveCommand}"/>
          <Button Content="Farklı Kaydet" Style="{StaticResource StudioButton}" Command="{Binding SaveAsCommand}"/>
          <Button Content="Yazdır" Style="{StaticResource StudioButton}" Command="{Binding PrintCommand}"/>
        </StackPanel>

        <Separator Grid.Column="1" Margin="12,0" Width="1" Background="#DFE5EE"/>

        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="{Binding PageLabel}" VerticalAlignment="Center" Margin="8,0" FontWeight="SemiBold"/>
          <Button Content="-" Style="{StaticResource StudioButton}" MinWidth="34" Command="{Binding ZoomOutCommand}"/>
          <TextBlock Text="{Binding ZoomPercent, StringFormat={}{0:0}%}" VerticalAlignment="Center" Margin="8,0"/>
          <Button Content="+" Style="{StaticResource StudioButton}" MinWidth="34" Command="{Binding ZoomInCommand}"/>
          <Button Content="Sığdır" Style="{StaticResource StudioButton}" Command="{Binding FitWidthCommand}"/>
        </StackPanel>

        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
          <TextBox Width="220"
                   Height="32"
                   Margin="8,0,4,0"
                   VerticalContentAlignment="Center"
                   Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                   ToolTip="PDF metninde ara"/>
          <Button Content="Ara" Style="{StaticResource StudioButton}" Command="{Binding SearchCommand}"/>
          <Button Content="Önceki" Style="{StaticResource StudioButton}" Command="{Binding PreviousSearchResultCommand}"/>
          <Button Content="Sonraki" Style="{StaticResource StudioButton}" Command="{Binding NextSearchResultCommand}"/>
        </StackPanel>

        <TextBlock Grid.Column="5"
                   Text="{Binding DirtyLabel}"
                   VerticalAlignment="Center"
                   Foreground="#637083"
                   Margin="12,0,0,0"/>
      </Grid>
    </Border>

    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <Grid Grid.Column="0" Margin="16">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#DFE5EE" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock Text="{Binding CurrentFileName}" FontSize="18" FontWeight="SemiBold" Foreground="#172033"/>
              <TextBlock Text="{Binding StatusMessage}" Margin="0,3,0,0" Foreground="#637083"/>
            </StackPanel>
            <TextBlock Grid.Column="1" Text="{Binding PageLabel}" VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" Foreground="#2563EB"/>
          </Grid>
        </Border>

        <Border Grid.Row="1" Background="#DCE3ED" CornerRadius="8" ClipToBounds="True">
          <ScrollViewer x:Name="DocumentScrollViewer"
                        HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Auto"
                        PreviewMouseWheel="DocumentScrollViewer_PreviewMouseWheel">
            <Grid Margin="28" HorizontalAlignment="Center" VerticalAlignment="Top">
              <Border Background="White" BorderBrush="#C8D2DF" BorderThickness="1" Padding="0">
                <Grid Width="{Binding PageViewWidth}" Height="{Binding PageViewHeight}">
                  <Image Source="{Binding CurrentPageImage}"
                         Width="{Binding PageViewWidth}"
                         Height="{Binding PageViewHeight}"
                         Stretch="Fill"
                         RenderOptions.BitmapScalingMode="HighQuality"/>

                  <ItemsControl ItemsSource="{Binding VisibleSearchResults}" IsHitTestVisible="False">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <Canvas Width="{Binding PageViewWidth}" Height="{Binding PageViewHeight}"/>
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                      <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding ViewX}"/>
                        <Setter Property="Canvas.Top" Value="{Binding ViewY}"/>
                      </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Width="{Binding ViewWidth}"
                                Height="{Binding ViewHeight}"
                                Background="#FFF2A8"
                                BorderBrush="#E3B600"
                                BorderThickness="1"
                                Opacity="0.65"/>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>

                </Grid>
              </Border>
            </Grid>
          </ScrollViewer>
        </Border>
      </Grid>

    </Grid>

    <ProgressBar Grid.Row="2"
                 Height="3"
                 IsIndeterminate="{Binding IsBusy}"
                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
  </Grid>
</UserControl>
